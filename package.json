{
  "name": "mathforge",
  "version": "0.0.0",
  "private": true,
  "description": "A visual canvas for composing mathematical formulas, methods, and algorithms as type-safe directed graphs of blocks.",
  "license": "MIT",
  "author": "k1bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/k1bot2026/MathForge"
  },
  "type": "module",
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate:fixtures": "node scripts/generate-sympy-fixtures.mjs",
    "check:fixtures": "node scripts/generate-sympy-fixtures.mjs && git diff --exit-code tests/fixtures/sympy/"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@xyflow/react": "12.10.2",
    "comlink": "4.4.2",
    "fflate": "0.8.2",
    "mathjs": "15.2.0",
    "next": "16.2.4",
    "pyodide": "0.29.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "three": "0.184.0",
    "zod": "4.4.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@playwright/test": "1.59.1",
    "@storybook/nextjs": "10.3.6",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@types/three": "0.184.0",
    "@vitest/coverage-v8": "4.1.5",
    "fast-check": "4.7.0",
    "jsdom": "^25.0.1",
    "storybook": "10.3.6",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "^6.0.7",
    "vitest": "4.1.5",
    "webpack": "^5.97.1"
  }
}
